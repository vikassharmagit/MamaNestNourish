{
  "name": "mama-nest-nourish",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test",
    "update:sources": "node scripts/updateDataSources.js",
    "validate:sources": "node scripts/validateSourceData.js",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "cd android && gradlew.bat assembleDebug",
    "android:release:apk": "cd android && gradlew.bat assembleRelease",
    "android:release:aab": "cd android && gradlew.bat bundleRelease"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1061.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0"
  }
}
